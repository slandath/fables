{
  "name": "@fables/backend",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env -r tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@fables/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "better-auth": "^1.0.0",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
